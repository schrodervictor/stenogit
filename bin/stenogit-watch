#!/usr/bin/env bash
#
# stenogit-watch — long-running inotify watcher that triggers
# stenogit-commit after a quiet window (DEBOUNCE seconds).
#
# Reads from environment:
#   DIR              (required) directory to watch (recursive)
#   DEBOUNCE         (optional) quiet-window seconds, default 5
#   STENOGIT_COMMIT  (optional) commit command, default "stenogit-commit"
#
# All other env vars (INSTANCE, MESSAGE_TEMPLATE) are passed through to the
# commit command unchanged.

sgw_run_commit() {
    local cmd="${STENOGIT_COMMIT:-stenogit-commit}"
    "$cmd"
}

sgw_debounce_loop() {
    local debounce="$1"
    local line
    while read -r line; do
        # Drain further events; each new event resets the timer.
        # When `read -t` times out the inner loop ends and we fire.
        while read -r -t "$debounce" line; do
            :
        done
        sgw_run_commit || true
    done
}

sgw_main() {
    local dir="${DIR:-}"
    local debounce="${DEBOUNCE:-5}"

    if [[ -z "$dir" ]]; then
        printf 'stenogit-watch: DIR is required\n' >&2
        return 1
    fi
    if [[ ! -d "$dir" ]]; then
        printf 'stenogit-watch: directory does not exist: %s\n' "$dir" >&2
        return 1
    fi

    inotifywait -m -r -q -e modify,create,delete,move "$dir" \
        | sgw_debounce_loop "$debounce"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail
    sgw_main "$@"
fi
