#!/usr/bin/env bash
#
# stenogit-commit - stage and commit any changes in $DIR.
#
# Reads from environment:
#   DIR              (required) target directory; must already be a git repo
#   INSTANCE         (optional) instance name, used in {name} placeholder
#   MESSAGE_TEMPLATE (optional) commit message template
#
# Exits 0 on success, including when there is nothing to commit (no-op).
# Exits non-zero with a clear message on misconfiguration.

SG_DEFAULT_MESSAGE='auto: {date}'

sg_err() { printf '%s\n' "$1" >&2; }

sg_check_dir() {
    local dir="$1"
    if [[ -z "$dir" ]]; then
        sg_err 'stenogit-commit: DIR is required'
        return 1
    fi
    if [[ ! -d "$dir" ]]; then
        sg_err "stenogit-commit: directory does not exist: $dir"
        return 1
    fi
    if [[ ! -d "$dir/.git" ]]; then
        sg_err "stenogit-commit: not a git repository: $dir (run \`stenogit add\` first)"
        return 1
    fi
}

sg_stage_all() {
    git -C "$1" add -A || return 1
}

sg_has_staged_changes() {
    ! git -C "$1" diff --cached --quiet
}

sg_count_staged() {
    git -C "$1" diff --cached --name-only | wc -l
}

sg_expand_template() {
    local template="$1"
    local instance="$2"
    local count="$3"
    local result="$template"
    result="${result//\{date\}/$(date -Iseconds)}"
    result="${result//\{count\}/$count}"
    result="${result//\{host\}/$(hostname)}"
    result="${result//\{name\}/$instance}"
    printf '%s' "$result"
}

sg_do_commit() {
    git -C "$1" commit -q -m "$2" || return 1
}

sg_main() {
    local dir="${DIR:-}"
    local instance="${INSTANCE:-default}"
    # Note: cannot use ${MESSAGE_TEMPLATE:-auto: {date}} -- bash ${...}
    # default-value parsing does not balance literal braces, so a `}`
    # inside the default leaks into the expansion.
    local template="${MESSAGE_TEMPLATE:-}"
    [[ -n "$template" ]] || template="$SG_DEFAULT_MESSAGE"

    sg_check_dir "$dir" || return 1
    sg_stage_all "$dir" || return 1

    if ! sg_has_staged_changes "$dir"; then
        return 0
    fi

    local count message
    count=$(sg_count_staged "$dir")
    message=$(sg_expand_template "$template" "$instance" "$count")
    sg_do_commit "$dir" "$message"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail
    sg_main "$@"
fi
