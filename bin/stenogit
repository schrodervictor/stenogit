#!/usr/bin/env bash
#
# stenogit - CLI that hides systemd from end users.
#
# Subcommands:
#   add <name> <dir> [options]   Register a new tracked directory
#   remove <name> [--user]       Unregister a tracked directory
#   list                         List configured instances
#
# add options:
#   --user                    Use per-user systemd units (default: system)
#   --schedule <interval>     Use a systemd timer (e.g. 10min, 1h)
#   --watch                   Use inotify watcher (mutually exclusive with --schedule)
#   --message <template>      Commit message template
#   --debounce <seconds>      Debounce window for --watch (default 5)
#   --max-wait <seconds>      Max time before forced commit (default 60; 0 disables)
#   --git-name <name>         Git user.name for the tracked repo
#   --git-email <email>       Git user.email for the tracked repo
#
# System mode (default) stores config in /etc/stenogit/ and uses system
# units. Requires root. User mode (--user) stores config under
# $XDG_CONFIG_HOME/stenogit/ and uses user units. No root needed.
#
# Tests override STENOGIT_CONFIG_DIR and STENOGIT_SYSTEMD_DIR directly.

_SG_SCOPE=system

sg_set_paths() {
    local scope="$1"
    _SG_SCOPE="$scope"
    if [[ "$scope" == "user" ]]; then
        STENOGIT_CONFIG_DIR="${STENOGIT_USER_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/stenogit}"
        STENOGIT_SYSTEMD_DIR="${STENOGIT_USER_SYSTEMD_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user}"
    else
        STENOGIT_CONFIG_DIR="${STENOGIT_SYSTEM_CONFIG_DIR:-/etc/stenogit}"
        STENOGIT_SYSTEMD_DIR="${STENOGIT_SYSTEM_SYSTEMD_DIR:-/etc/systemd/system}"
    fi
}

sg_require_root() {
    if [[ -n "${STENOGIT_SKIP_ROOT_CHECK:-}" ]]; then
        return 0
    fi
    if [[ "$(id -u)" -ne 0 ]]; then
        printf 'stenogit: system mode requires root. Use sudo, or pass --user for per-user mode.\n' >&2
        return 1
    fi
}

sg_usage() {
    cat <<'EOF'
Usage:
  stenogit add <name> <dir> [options]
  stenogit remove <name> [--user]
  stenogit list

Options for add:
  --user                    Use per-user systemd units (default: system)
  --schedule <interval>     Use a systemd timer (e.g. 10min, 1h)
  --watch                   Use inotify watcher (mutually exclusive with --schedule)
  --message <template>      Commit message template
  --debounce <seconds>      Debounce window for --watch (default 5)
  --max-wait <seconds>      Max time before forced commit (default 60; 0 disables)
  --git-name <name>         Git user.name for the tracked repo
  --git-email <email>       Git user.email for the tracked repo
EOF
}

sg_validate_name() {
    local name="$1"
    if [[ -z "$name" ]]; then
        printf 'stenogit: instance name is required\n' >&2
        return 1
    fi
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        printf 'stenogit: invalid instance name: %s (use [a-zA-Z0-9_-]+)\n' "$name" >&2
        return 1
    fi
}

sg_init_repo() {
    local dir="$1"
    local git_name="${2:-Stenogit}"
    local git_email="${3:-stenogit@$(hostname)}"
    if [[ ! -d "$dir/.git" ]]; then
        git -C "$dir" init -q
    fi
    git -C "$dir" config user.name "$git_name"
    git -C "$dir" config user.email "$git_email"
}

sg_write_conf() {
    local name="$1" dir="$2" message="$3" debounce="$4" max_wait="$5"
    mkdir -p "$STENOGIT_CONFIG_DIR"
    local conf="$STENOGIT_CONFIG_DIR/$name.conf"
    {
        printf 'DIR=%s\n' "$dir"
        printf 'MESSAGE_TEMPLATE=%s\n' "$message"
        printf 'DEBOUNCE=%s\n' "$debounce"
        printf 'MAX_WAIT=%s\n' "$max_wait"
    } > "$conf"
}

sg_remove_conf() {
    local name="$1"
    rm -f "$STENOGIT_CONFIG_DIR/$name.conf"
}

sg_write_schedule_dropin() {
    local name="$1" interval="$2"
    local dir="$STENOGIT_SYSTEMD_DIR/stenogit@$name.timer.d"
    mkdir -p "$dir"
    cat > "$dir/schedule.conf" <<EOF
[Timer]
OnUnitActiveSec=
OnUnitActiveSec=$interval
EOF
}

sg_remove_schedule_dropin() {
    local name="$1"
    rm -rf "$STENOGIT_SYSTEMD_DIR/stenogit@$name.timer.d"
}

sg_systemctl() {
    if [[ "$_SG_SCOPE" == "user" ]]; then
        systemctl --user "$@"
    else
        systemctl "$@"
    fi
}

sg_enable_timer() {
    local name="$1"
    sg_systemctl daemon-reload
    sg_systemctl enable --now "stenogit@$name.timer"
}

sg_enable_watch() {
    local name="$1"
    sg_systemctl daemon-reload
    sg_systemctl enable --now "stenogit-watch@$name.service"
}

sg_disable_all() {
    local name="$1"
    sg_systemctl disable --now "stenogit@$name.timer" 2>/dev/null || true
    sg_systemctl disable --now "stenogit-watch@$name.service" 2>/dev/null || true
}

cmd_add() {
    local name="" dir="" message="auto: {date}"
    local schedule="" watch=0 debounce=5 max_wait=60
    local git_name="" git_email=""
    local scope="system"

    if [[ $# -lt 2 ]]; then
        sg_usage >&2
        return 1
    fi
    name="$1"; shift
    dir="$1"; shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --user)      scope="user";     shift ;;
            --schedule)  schedule="$2";    shift 2 ;;
            --watch)     watch=1;          shift ;;
            --message)   message="$2";     shift 2 ;;
            --debounce)  debounce="$2";    shift 2 ;;
            --max-wait)  max_wait="$2";    shift 2 ;;
            --git-name)  git_name="$2";    shift 2 ;;
            --git-email) git_email="$2";   shift 2 ;;
            *)
                printf 'stenogit: unknown option: %s\n' "$1" >&2
                return 1
                ;;
        esac
    done

    sg_validate_name "$name" || return 1

    if [[ ! -d "$dir" ]]; then
        printf 'stenogit: directory does not exist: %s\n' "$dir" >&2
        return 1
    fi

    if [[ -n "$schedule" && "$watch" -eq 1 ]]; then
        printf 'stenogit: --schedule and --watch are mutually exclusive\n' >&2
        return 1
    fi

    sg_set_paths "$scope"
    if [[ "$scope" == "system" ]]; then
        sg_require_root || return 1
    fi

    sg_init_repo "$dir" "$git_name" "$git_email" || return 1
    sg_write_conf "$name" "$dir" "$message" "$debounce" "$max_wait" || return 1

    if [[ "$watch" -eq 1 ]]; then
        sg_enable_watch "$name" || return 1
    else
        if [[ -n "$schedule" ]]; then
            sg_write_schedule_dropin "$name" "$schedule" || return 1
        fi
        sg_enable_timer "$name" || return 1
    fi
}

cmd_remove() {
    local name="" scope=""

    if [[ $# -lt 1 ]]; then
        sg_usage >&2
        return 1
    fi
    name="$1"; shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --user) scope="user"; shift ;;
            *)
                printf 'stenogit: unknown option: %s\n' "$1" >&2
                return 1
                ;;
        esac
    done

    sg_validate_name "$name" || return 1

    if [[ -z "$scope" ]]; then
        local sys_dir="${STENOGIT_SYSTEM_CONFIG_DIR:-/etc/stenogit}"
        local usr_dir="${STENOGIT_USER_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/stenogit}"
        if [[ -f "$sys_dir/$name.conf" ]]; then
            scope="system"
        elif [[ -f "$usr_dir/$name.conf" ]]; then
            scope="user"
        else
            printf 'stenogit: no instance found: %s\n' "$name" >&2
            return 1
        fi
    fi

    sg_set_paths "$scope"
    if [[ "$scope" == "system" ]]; then
        sg_require_root || return 1
    fi

    sg_disable_all "$name"
    sg_remove_schedule_dropin "$name"
    sg_remove_conf "$name"
}

cmd_list() {
    local conf
    local sys_dir="${STENOGIT_SYSTEM_CONFIG_DIR:-/etc/stenogit}"
    local usr_dir="${STENOGIT_USER_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/stenogit}"
    shopt -s nullglob
    if [[ -d "$sys_dir" ]]; then
        for conf in "$sys_dir"/*.conf; do
            printf '%s\tsystem\n' "$(basename "$conf" .conf)"
        done
    fi
    if [[ -d "$usr_dir" ]]; then
        for conf in "$usr_dir"/*.conf; do
            printf '%s\tuser\n' "$(basename "$conf" .conf)"
        done
    fi
    shopt -u nullglob
}

sg_main() {
    local cmd="${1:-}"
    [[ $# -gt 0 ]] && shift
    case "$cmd" in
        add)         cmd_add "$@" ;;
        remove|rm)   cmd_remove "$@" ;;
        list|ls)     cmd_list "$@" ;;
        ""|-h|--help|help) sg_usage ;;
        *)           sg_usage >&2; return 1 ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail
    sg_main "$@"
fi
